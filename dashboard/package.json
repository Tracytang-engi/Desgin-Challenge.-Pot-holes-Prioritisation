{
  "name": "pothole-dashboard",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "ensure-data": "node scripts/ensure-data.js",
    "fix-data": "node scripts/inject-potholes.js",
    "dev": "node scripts/copy-data.js && vite",
    "build": "node scripts/copy-data.js && tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "demo": "npm run ensure-data && concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
